{
  "name": "cinema-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm --prefix cinema-api run start:dev\" \"npm --prefix cineweb run dev\"",
    "backend:dev": "npm --prefix cinema-api run start:dev",
    "frontend:dev": "npm --prefix cineweb run dev",
    "build": "npm --prefix cinema-api run build && npm --prefix cineweb run build",
    "preview": "npm --prefix cineweb run preview",
    "prisma:generate": "npm --prefix cinema-api run prisma:generate",
    "prisma:migrate": "npm --prefix cinema-api run prisma:migrate",
    "prisma:studio": "npm --prefix cinema-api run prisma:studio"
  },
  "dependencies": {
    "concurrently": "^8.2.1"
  },
  "devDependencies": {}
}
